# Copy this file to ".env" and paste your Klaviyo PRIVATE API key.
# Get one at: Klaviyo -> Settings -> API Keys -> Create Private API Key
# (read-only scopes are enough). Never commit your real .env file.

KLAVIYO_API_KEY=pk_your_private_key_here

# Optional: change the port the dashboard runs on (default 8000)
# PORT=8000
